# -----------------------------------------------
# macOS system files
# -----------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
.fseventsd


# -----------------------------------------------
# macOS / iCloud aliases
# -----------------------------------------------
*alias
*alias/
*.icloud


# -----------------------------------------------
# Windows & Linux system files
# -----------------------------------------------
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/


# -----------------------------------------------
# Credentials, API keys, secrets
# (absolute — no exceptions)
# -----------------------------------------------
.env
.env.*
!.env.example
!.env.template
.env.local
.env.development.local
.env.test.local
.env.production.local
*.key
*.pem
*.p12
*.pfx
credentials/
secrets/
keys/
*service_account*
*service-account*
*google-credentials*
*google_credentials*
.gws/
gws-credentials*
.tokens/
.cache_ggshield

# JSON: blocked by default — prevents accidental credential commits.
# Named exceptions for this React/Hardhat project:
*.json
!package.json
!package-lock.json
!tsconfig*.json
!.eslintrc.json
!.prettierrc.json
!hardhat.config.json


